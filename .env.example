# ==============================================================
# SupplySense Environment Variables
# Copy this file to .env and fill in your values
# ==============================================================

# ── Databases & Infrastructure ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://admin:password@postgres:5432/supplysense
MONGODB_URL=mongodb://admin:password@mongodb:27017/supplysense
REDIS_URL=redis://redis:6379/0
ELASTICSEARCH_URL=http://elasticsearch:9200
QDRANT_URL=http://qdrant:6333
INFLUXDB_URL=http://influxdb:8086

# ── Message Broker ────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── MLflow Tracking ───────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── AI APIs ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── External Data APIs ────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your-openweather-api-key
ALPHAVANTAGE_API_KEY=your-alphavantage-api-key
NEWSAPI_KEY=your-newsapi-key
TWELVE_DATA_API_KEY=your-twelve-data-api-key

# ── Maps & UI ─────────────────────────────────────────────────────────────────
# Maps use OpenStreetMap + Leaflet (no API key needed)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Cloud Infrastructure (AWS) ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=supplysense-assets

# ── Authentication & Security ─────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ── Communication & Alerts ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=+14155238886
SENDGRID_API_KEY=SG.your-sendgrid-api-key
